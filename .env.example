# Zabbix API Configuration
ZABBIX_API_URL=http://zabbix:8080/api_jsonrpc.php
ZABBIX_API_TOKEN=your_zabbix_api_token_here

# Proxmox API Configuration
PROXMOX_HOST=pve-r720.bmic.local
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=inframon-token
PROXMOX_TOKEN_SECRET=your_proxmox_token_secret_here
PROXMOX_VERIFY_SSL=false

# Web UI Configuration
PORT=3000
NODE_ENV=production

# Pi Agent Configuration
PI_MODEL=claude-opus-4-6
PI_THINKING_LEVEL=off

# Optional: LiteLLM Proxy
LITELLM_PROXY_URL=http://localhost:8000
