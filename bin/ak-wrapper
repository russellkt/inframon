#!/usr/bin/env python3
"""
ak wrapper — loads env from /proc/1/environ before calling the real ak binary.
OpenFang strips env vars from shell_exec subprocesses; this wrapper restores them.
Installed as /usr/local/bin/ak (real binary moved to /usr/local/bin/ak-bin).
"""
import os, sys, subprocess
from pathlib import Path

p = Path('/proc/1/environ')
if p.exists():
    for entry in p.read_bytes().split(b'\x00'):
        if b'=' in entry:
            k, v = entry.decode('utf-8', errors='replace').split('=', 1)
            os.environ.setdefault(k, v)

sys.exit(subprocess.run(['/usr/local/bin/ak-bin'] + sys.argv[1:]).returncode)
