# OpenFang Environment Variables for Inframon
# Copy to ../.env and fill in your values

# ── LLM Provider ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Ollama for local models (free, private)
# OLLAMA_BASE_URL=http://10.10.1.149:11434

# Optional: Anthropic direct (bypasses OpenRouter)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Infrastructure APIs ──────────────────────────────────────────────
ZABBIX_API_URL=http://10.10.1.142/api_jsonrpc.php
ZABBIX_API_TOKEN=your_zabbix_api_token_here

# ── SSH Key for Proxmox/Switch Access ────────────────────────────────
# Path to the dedicated inframon SSH private key (NOT your personal key)
# Generate with: ssh-keygen -t ed25519 -f openfang/ssh/id_ed25519 -N "" -C "inframon@bmic"
INFRAMON_SSH_KEY=./openfang/ssh/id_ed25519

# ── Notification ─────────────────────────────────────────────────────
# Load from ~/.config/infra-monitor/.env inside container
# NOTIFY_WEBHOOK_URL=
# NOTIFY_WEBHOOK_API_KEY=

# ── Google Chat (Phase 2) ────────────────────────────────────────────
# GOOGLE_CHAT_SA_KEY=/data/google-chat-sa.json

# ── OpenFang Settings ────────────────────────────────────────────────
OPENFANG_HOME=/data
RUST_LOG=info
