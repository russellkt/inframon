{
  "name": "bmic-inframon",
  "version": "0.1.0",
  "description": "AI-powered infrastructure monitoring and troubleshooting service for Zabbix + Proxmox",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "pm2-dev pm2.config.js",
    "build": "npm run build:web-ui",
    "build:web-ui": "cd web-ui-app && npm run build",
    "preview": "cd web-ui-app && npm run preview",
    "start": "pm2-runtime start pm2.config.js",
    "logs": "pm2 logs",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-tui": "^0.57.1",
    "@mariozechner/pi-web-ui": "^0.57.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.3"
  }
}
